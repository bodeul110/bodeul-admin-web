# 관리자 웹 Firebase Web config
VITE_FIREBASE_API_KEY=<firebase-web-api-key>
VITE_FIREBASE_AUTH_DOMAIN=<firebase-auth-domain>
VITE_FIREBASE_PROJECT_ID=<firebase-project-id>
VITE_FIREBASE_STORAGE_BUCKET=<firebase-storage-bucket>
VITE_FIREBASE_MESSAGING_SENDER_ID=<firebase-messaging-sender-id>
VITE_FIREBASE_APP_ID=<firebase-web-app-id>

# 선택: App Check를 붙일 때만 설정한다.
VITE_FIREBASE_APPCHECK_SITE_KEY=
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=

# 선택: bodeul-api read API 전환 검증.
# 기본값은 firebase이며, api로 바꾸면 관리자 웹 병원 가이드 화면에서 bodeul-api를 호출한다.
VITE_BODEUL_DATA_BACKEND=firebase
VITE_BODEUL_API_BASE_URL=http://127.0.0.1:8080
