# 브라우저에 공개되는 Firebase Web config
NEXT_PUBLIC_FIREBASE_API_KEY=<firebase-web-api-key>
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=<firebase-auth-domain>
NEXT_PUBLIC_FIREBASE_PROJECT_ID=<firebase-project-id>
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=<firebase-storage-bucket>
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=<firebase-messaging-sender-id>
NEXT_PUBLIC_FIREBASE_APP_ID=<firebase-web-app-id>

# 선택: Next.js 전환 중 기존 reCAPTCHA v3 App Check 설정
NEXT_PUBLIC_FIREBASE_APPCHECK_SITE_KEY=

# 로컬 전용. App Check debug token은 Preview/Production에 넣지 않는다.
NEXT_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=

# Next.js 기본값은 api + 동일 출처다. 외부 Node API 비교가 필요할 때만 URL을 설정한다.
NEXT_PUBLIC_BODEUL_DATA_BACKEND=api
NEXT_PUBLIC_BODEUL_API_BASE_URL=

# 서버 전용. Supabase transaction pooler(6543)의 bodeul_admin_service URL을 사용한다.
ADMIN_DATABASE_URL=<postgresql-transaction-pooler-url>
FIREBASE_PROJECT_ID=<firebase-project-id>

# Vite rollback은 아래 기존 이름도 지원한다. 서버 비밀값은 VITE_ 이름으로 만들지 않는다.
VITE_FIREBASE_API_KEY=<firebase-web-api-key>
VITE_FIREBASE_AUTH_DOMAIN=<firebase-auth-domain>
VITE_FIREBASE_PROJECT_ID=<firebase-project-id>
VITE_FIREBASE_STORAGE_BUCKET=<firebase-storage-bucket>
VITE_FIREBASE_MESSAGING_SENDER_ID=<firebase-messaging-sender-id>
VITE_FIREBASE_APP_ID=<firebase-web-app-id>
VITE_FIREBASE_APPCHECK_SITE_KEY=
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=
VITE_BODEUL_DATA_BACKEND=firebase
VITE_BODEUL_API_BASE_URL=
